		{
			"name": "2-CreateAUserByRandomEmailandStoreuserID",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"const response = pm.response.json(); // Parse the JSON response from the API\r",
							"const user_id = response.id; // Extract the user_id from the response object\r",
							"console.log(\"user id===>\" + user_id); // print the user_id to the console for debugging\r",
							"pm.variables.set(\"userID\", user_id); // Set the user_id as a Postman variable\r",
							"//local variable name is 'userID'\r",
							"console.log(\"Response JSON:\", response);\r",
							"console.log(\"Extracted User ID:\", user_id);\r",
							"console.log(\"User ID Set in Variables:\", pm.variables.get(\"userID\"));\r",
							"//scope of local variable is it's always top priority for variables. i.e it will print first\r",
							"\r",
							" //LDECG\r",
							"\r",
							"\r",
							"//test cases:\r",
							"pm.test(\"Status code is 201\", function () {\r",
							"    pm.response.to.have.status(201);\r",
							"});\r",
							"\r",
							"pm.test(\"check user name is naveen\", function () {\r",
							"    var jsonData = pm.response.json();\r",
							"    pm.expect(jsonData.name).to.eql(\"naveen\");\r",
							"});\r",
							"\r",
							"pm.test(\"Content-Type is present\", function () {\r",
							"    pm.response.to.have.header(\"Content-Type\");\r",
							"});\r",
							"\r",
							""
						],
						"type": "text/javascript",
						"packages": {}
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "{{tokenID}}",
						"type": "text"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\r\n    //\"name\": \"{{$randomUserName}}\",\r\n    \"name\": \"naveen\",\r\n    \"gender\": \"male\",\r\n    \"email\": \"apiautomation_{{$randomEmail}}\", //HERE THE ADVANTAGE OF ADDING 'APIAUTOMATION_' IS TO FIND THE EMAILID EASILY FROM DB AND DELETE THEM\r\n    \"status\": \"active\"\r\n}",
					"options": {
